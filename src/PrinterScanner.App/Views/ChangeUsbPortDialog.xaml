<Window x:Class="PrinterScanner.App.Views.ChangeUsbPortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterar Porta USB"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Background="#F0F3F7">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <Style TargetType="Label">
      <Setter Property="Foreground" Value="#44515E"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="0,0,0,2"/>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Height" Value="30"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Height" Value="34"/>
      <Setter Property="MinWidth" Value="100"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="BorderBrush" Value="#C7D0DA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="20">

    <!-- Cabeçalho -->
    <Border Padding="12,10" Background="#FFFFFF" BorderBrush="#C8D1DB" BorderThickness="1" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#22303B"
                   Text="Alterar porta USB da impressora" />
        <TextBlock Margin="0,4,0,0" Foreground="#65717D" FontSize="12"
                   Text="{Binding PrinterName, StringFormat='Impressora: {0}'}" />
        <TextBlock Margin="0,2,0,0" Foreground="#65717D" FontSize="12"
                   Text="{Binding CurrentPort, StringFormat='Porta atual: {0}'}" />
      </StackPanel>
    </Border>

    <!-- Seleção de porta -->
    <Label Content="Nova porta USB" />
    <ComboBox ItemsSource="{Binding AvailablePorts}"
              SelectedItem="{Binding SelectedPort, UpdateSourceTrigger=PropertyChanged}" />

    <!-- Carregando -->
    <TextBlock Text="Carregando portas disponíveis..."
               FontSize="11" Foreground="#888" Margin="0,6,0,0"
               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

    <!-- Status -->
    <Border Margin="0,14,0,0" Padding="10,8"
            Background="#EEF4FF" BorderBrush="#B0C8F0" BorderThickness="1"
            Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#1A4C8B" TextWrapping="Wrap" FontSize="12"/>
    </Border>

    <!-- Botões -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancelar" Click="Cancel_Click" Background="#FFFFFF" Foreground="#44515E" Margin="0,0,8,0"/>
      <Button x:Name="BtnApply" Content="Aplicar" Click="Apply_Click"
              Background="#7B1FA2" Foreground="White" BorderBrush="#6A1B9A"
              IsEnabled="{Binding CanApply}"/>
    </StackPanel>

  </StackPanel>
</Window>
