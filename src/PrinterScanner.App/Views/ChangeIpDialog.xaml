<Window x:Class="PrinterScanner.App.Views.ChangeIpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:PrinterScanner.App.Views"
        Title="Alterar IP da Impressora"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F0F3F7">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <Style TargetType="TextBox">
      <Setter Property="Height" Value="30"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,2"/>
      <Setter Property="BorderBrush" Value="#C6CED8"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style TargetType="Label">
      <Setter Property="Foreground" Value="#44515E"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="0,0,0,2"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Height" Value="34"/>
      <Setter Property="MinWidth" Value="100"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="BorderBrush" Value="#C7D0DA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="20">

    <!-- Cabeçalho -->
    <Border Padding="12,10" Background="#FFFFFF" BorderBrush="#C8D1DB" BorderThickness="1" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#22303B" Text="Alterar configuracoes de rede" />
        <TextBlock Margin="0,4,0,0" Foreground="#65717D" FontSize="12"
                   Text="{Binding CurrentIp, StringFormat='Impressora atual: {0}'}" />
      </StackPanel>
    </Border>

    <!-- Campos -->
    <Label Content="Novo IP" />
    <TextBox x:Name="TxtNewIp" Text="{Binding NewIp, UpdateSourceTrigger=PropertyChanged}" />

    <Label Content="Mascara de sub-rede" Margin="0,10,0,0"/>
    <TextBox x:Name="TxtMask" Text="{Binding NewMask, UpdateSourceTrigger=PropertyChanged}" />

    <Label Content="Gateway padrao" Margin="0,10,0,0"/>
    <TextBox x:Name="TxtGateway" Text="{Binding NewGateway, UpdateSourceTrigger=PropertyChanged}" />

    <Label Content="Metodo de configuracao" Margin="0,10,0,0"/>
    <ComboBox Height="30" FontSize="13"
              ItemsSource="{Binding Source={x:Static local:ChangeIpViewModel.AvailableProtocols}}"
              SelectedItem="{Binding SelectedProtocol}"
              DisplayMemberPath="DisplayName"/>

    <!-- Status -->
    <Border x:Name="StatusBorder" Margin="0,16,0,0" Padding="10,8"
            Background="#EEF4FF" BorderBrush="#B0C8F0" BorderThickness="1"
            Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#1A4C8B" TextWrapping="Wrap" FontSize="12"/>
    </Border>

    <!-- Barra de progresso -->
    <ProgressBar x:Name="Progress" Height="6" Margin="0,8,0,0"
                 Minimum="0" Maximum="100"
                 Value="{Binding ProgressValue, Mode=OneWay}"
                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

    <!-- Botões -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancelar" Click="Cancel_Click" Background="#FFFFFF" Foreground="#44515E" Margin="0,0,8,0"/>
      <Button x:Name="BtnApply" Content="Aplicar" Click="Apply_Click"
              Background="#2B77D1" Foreground="White" BorderBrush="#2365B4"
              IsEnabled="{Binding CanApply}"/>
    </StackPanel>

  </StackPanel>
</Window>
